		{
			"name": "3. Financial Records",
			"item": [
				{
					"name": "Get All Records (With Filters)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/records?page=0&size=10&sortBy=date&sortDir=desc",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"records"
							],
							"query": [
								{
									"key": "page",
									"value": "0"
								},
								{
									"key": "size",
									"value": "10"
								},
								{
									"key": "sortBy",
									"value": "date"
								},
								{
									"key": "sortDir",
									"value": "desc"
								},
								{
									"key": "type",
									"value": "EXPENSE",
									"disabled": true
								},
								{
									"key": "category",
									"value": "Rent",
									"disabled": true
								},
								{
									"key": "search",
									"value": "Salary",
									"disabled": true
								},
								{
									"key": "startDate",
									"value": "2026-01-01",
									"disabled": true
								},
								{
									"key": "endDate",
									"value": "2026-04-30",
									"disabled": true
								}
							]
						}
					}
				},
